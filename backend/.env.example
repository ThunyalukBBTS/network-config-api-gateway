# Server Configuration
PORT=3000
HOST=0.0.0.0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=3600

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/network_gateway

# Protocol Selection
# Choose preferred protocol: 'netconf' or 'gnmi'
# Default: netconf (for backward compatibility)
PREFERRED_PROTOCOL=netconf

# gNMI Configuration
GNMI_HOST=172.20.20.4
GNMI_PORT=57400
GNMI_USERNAME=admin
GNMI_PASSWORD=NokiaSrl1!
GNMI_INSECURE=true
# Enable/disable gNMI (default: true)
GNMI_ENABLED=true
# Connection timeout in milliseconds (default: 30000)
GNMI_TIMEOUT=30000

# NETCONF Configuration
NETCONF_HOST=192.168.1.1
NETCONF_PORT=830
NETCONF_USERNAME=admin
NETCONF_PASSWORD=admin
# Connection timeout in milliseconds (default: 30000)
NETCONF_TIMEOUT=30000
# Auto-connect on first RPC (default: true)
NETCONF_AUTOCONNECT=true

# NETCONF Configuration for mock using frr
# NETCONF_HOST=127.0.0.1
# NETCONF_PORT=830
# NETCONF_USERNAME=root
# NETCONF_PASSWORD=frrpassword

# Mock Mode (for development without router)
MOCK_MODE=true
